# Copiez ce fichier en ".env" (sans ".example") à la racine du projet,
# à côté de manage.py, puis renseignez vos propres valeurs.
# Le fichier ".env" ne doit JAMAIS être committé (voir .gitignore).

# Clé secrète Django — générez-en une nouvelle pour chaque environnement :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-moi-en-une-vraie-cle-secrete-unique

# Mettre à False en production
DEBUG=True

# Domaines/IP autorisés à servir l'app, séparés par des virgules
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL (obligatoire — plus de SQLite).
# Avec Docker (docker-compose), le hôte est le nom du service : "db".
# DATABASE_URL doit rester cohérent avec POSTGRES_* ci-dessous.
DATABASE_URL=postgres://recensement:changez-ce-mot-de-passe@db:5432/recensement

# Variables individuelles utilisées par le conteneur PostgreSQL lui-même
# (docker-compose.yml les lit directement ; doivent correspondre à DATABASE_URL ci-dessus).
POSTGRES_DB=recensement
POSTGRES_USER=recensement
POSTGRES_PASSWORD=changez-ce-mot-de-passe

# Fuseau horaire et langue (déjà adaptés au Bénin dans settings.py, mais
# surchargeables ici si besoin)
TIME_ZONE=Africa/Porto-Novo
LANGUAGE_CODE=fr-fr
